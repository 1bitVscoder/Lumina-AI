# Supabase Config
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-for-verification

# LLM Config
GEMINI_API_KEY=your-gemini-api-key

# API Security Config
ALLOWED_ORIGINS=*
# JSON array of valid client API keys for route protection
API_KEYS_JSON=["key1", "key2"]
